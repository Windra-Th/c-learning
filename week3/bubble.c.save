#include <stdio.h>

int input_scores(int scores[]);
void show_scores(int scores[],int count);
float calc_average(int scores[],int count);
int find_max(int scores[], int count);
//总调用
int main() {
  int scores[100];
  int count;
  count = input_scores(scores);
  show_scores(scores,count);
  printf("平均值：%.2f\n",calc_average(scores,count));
  printf("最大值：%d\n",scores[find_max(scores,count)]);
  return 0;
}
//输入
int input_scores(int scores[]) {
  int count;
  printf("要输入几个成绩？");
  scanf("%d",&count);
  for (int i = 0;i < count;i++) {
    printf("输入第%d个成绩：",i+1);
    scanf("%d",&scores[i]);
  }
  return count;
}
//展示
void show_scores(int scores[],int count) {
  for (int i = 0;i < count;i++) {
    printf("%d  ",scores[i]);
  }
  printf("\n");
}
//平均值
float calc_average(int scores[],int count) {
  int sum = 0;
  for (int i = 0;i < count;i++) {
    sum = sum + scores[i];
  }
  return (float)sum/count;
}
//最大值
int find_max(int scores[], int count) {
  int max_index = 0;
  for (int i = 1; i < count; i++) {
    if (scores[i] > scores[max_index]) {
      max_index = i;
    }
  }
  return max_index;
}
//冒泡排序
void bubble_sort (int scores[],int count) {
  for (int i = 0;i < count - 1; i++) {
    for (int j = 0; j < count -1 - i; j++) {
      if (scores[i] > scores[i+1]) {
        int temp = scores[i];
        scores[i] = scores[i+1];
        scores[i+1] = temp;
      }
    }
  }



    if (scores[i] > scores[i+1]) {
      int temp = scores[i];
      scores[i] = scores[i+1];
      scores[i+1] = temp;
      i = 0;
    }
  }
}
